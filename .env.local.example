# ═══════════════════════════════════════════════════════════════════════
# Supabase (REQUIRED for Phase 2 auth)
# Get these from Supabase Dashboard → Settings → API
# ═══════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL — used for password reset email callbacks
# Dev: http://localhost:3000 · Prod: https://purex.fit
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp (defaults to number in lib/constants.ts if not set)
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Email (for booking confirmations)
RESEND_API_KEY=
EMAIL_FROM="PURE X <hello@purex.fit>"
EMAIL_ADMIN_INBOX=admin@purex.fit

# Rate limiting (optional, Phase 1)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
