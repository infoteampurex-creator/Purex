# ═══════════════════════════════════════════════════════════════════════
# Supabase (REQUIRED for Phase 2 auth)
# Get these from Supabase Dashboard → Settings → API
# ═══════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL — used for password reset email callbacks
# Dev: http://localhost:3000 · Prod: https://www.teampurex.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp (defaults to number in lib/constants.ts if not set)
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Email (Resend — used by signup approval / rejection, registration receipts)
#
# 1. Get the API key from https://resend.com/api-keys
# 2. Verify your sender domain in Resend → Domains. The address in
#    EMAIL_FROM must be on a domain you've verified, otherwise sends
#    fail with "Domain not verified" and the admin panel will surface
#    that error after every approve / reject.
# 3. Leave RESEND_API_KEY blank to skip email entirely (action still
#    succeeds; admin contacts the client via WhatsApp).
RESEND_API_KEY=
EMAIL_FROM="PURE X <hello@teampurex.com>"
EMAIL_ADMIN_INBOX=info.teampurex@gmail.com

# Rate limiting (optional, Phase 1)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# AI vision for meal photo logging (Phase 2 — Gemini 2.0 Flash)
# ═══════════════════════════════════════════════════════════════════════
# Get the key from https://aistudio.google.com/apikey (free; no card
# required). The free tier covers 1,500 requests/day — enough for ~12
# daily active users with 4 meals each. Paid pricing is ~$0.0003 per
# scan (≈ ₹0.025) which beats Claude/GPT-4o by ~100x for this use case.
#
# Used by lib/actions/analyze-meal-photo.ts — the mobile app's meal
# sheet sends a food photo, Gemini returns calories + macros.
# Leave blank to disable the AI flow (manual entry still works).
GOOGLE_AI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# Google Sheets integration (admin-curated content)
# ═══════════════════════════════════════════════════════════════════════
# Read-only sync from Google Sheets so the coach can edit certain
# datasets without a code change. Uses a service account — no per-user
# OAuth dance. Setup runbook: docs/google-sheets-integration.md
#
# Service account credentials. Get from Google Cloud → IAM → Service
# Accounts → Create → "PURE X Sheets Reader" → Add key (JSON). Two
# fields come straight off that JSON.
#
# IMPORTANT: when pasting the private key into Vercel's env var box,
# keep the literal "\n" sequences intact. The reader converts them
# back to real newlines at runtime.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Per-dataset Sheet IDs — the long string in the Sheet URL between
# /d/ and /edit. Each Sheet must be shared with the service-account
# email above as Viewer. Leave blank to skip that dataset.
SHEET_FOOD_LIBRARY_ID=
SHEET_WORKOUT_TEMPLATES_ID=
SHEET_PRICING_ID=
